{
  "name": "vfs4agent",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "FUSE-based virtual filesystem over a vector DB for LLM agents",
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx 'src/**/*.test.ts' 'examples/**/*.test.ts'",
    "ingest": "tsx src/cli/ingest.ts",
    "server": "tsx src/server.ts",
    "ask": "tsx src/cli/ask.ts",
    "start": "tsx src/agent/main.ts",
    "start:built": "node dist/agent/main.js",
    "docker:build": "docker compose build",
    "docker:run": "docker compose run --rm -it vfs-agent"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^11.7.0",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "fuse-native": "^2.2.6",
    "lru-cache": "^11.0.2",
    "openai": "^6.34.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "fuse-native"
    ]
  }
}
